# RAG Pipeline 環境變數設定
# 複製為 .env 後修改需要覆蓋的值

# RAG_OLLAMA_BASE_URL=http://localhost:11434
# RAG_LLM_MODEL=gemma3
# RAG_EMBEDDING_MODEL=nomic-embed-text
# RAG_CHROMA_PERSIST_PATH=./chroma_db
# RAG_TOP_K=5
# RAG_SCORE_THRESHOLD=0.3
# RAG_KEYWORD_BOOST=0.5
# RAG_CHUNK_SIZE=500
# RAG_CHUNK_OVERLAP=50
# RAG_OUTPUT_MODE=professional

# ── API 安全 ───────────────────────────────────────────────────
# Token：留空 = server 啟動時自動生成並寫到 .env.local（vite 自動讀）。
# 想自己控管就指定固定值。從 curl/postman 打 API 時需帶 X-Local-Token header。
# RAG_API_TOKEN=
#
# 操作者面（/admin）密碼，Basic Auth。設了就擋 /admin 頁面與所有管理類 API
# （ingest / profile 改動 / editor 執行 / eval / dashboard）；訪客 chat 端點
# （query / reset / GET profiles）永遠免密碼。留空 = 不擋。展場部署建議設。
# RAG_ADMIN_PASSWORD=
#
# CORS 允許的 origin（逗號分隔）。預設只接受本機 vite dev server，
# 如果要用 ngrok 等公開 demo 把 URL 加進來。
# RAG_API_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#
# Graph 節點上 source_path / persist_path / golden_set_path 等欄位
# 必須落在這些根目錄下（逗號分隔）。預設只允許專案內的三個資料夾。
# RAG_ALLOWED_DATA_ROOTS=./knowledge_base,./eval,./chroma_db

# ── 知識庫加密（at-rest encryption）─────────────────────────────────
# 啟用方式：跑一次 `make kb-encrypt`（或 python -m tools.encrypt_kb）建立
# keystore，之後知識庫來源檔、向量庫 chunk 全文、問答紀錄都以密文存放。
# 「有 keystore = 加密啟用」；沒有就維持明文（行為與現在完全相同）。
#
# 金鑰模型（hybrid）：密碼在開機後由操作者透過 /admin 或 POST /api/kb/unlock
# 輸入派生金鑰，金鑰只在記憶體、密碼不落地 → 連整顆磁碟被複製也無法解密。
# 代價：每次重開機要有人解鎖一次（kiosk 無人值守自動啟動會停在 locked）。
#
# keystore 路徑（只存 salt + verifier，不存密碼/金鑰）。預設專案內 config/。
# RAG_KB_KEYSTORE=./config/kb_keystore.json
#
# migration 用：設了就免互動輸入密碼（CI / 自動化）。平時不要設、不要存進 .env。
# RAG_KB_PASSPHRASE=
#
# 建議把 RAG_ADMIN_PASSWORD 設成與解鎖密碼相同 → 一組密碼同時管 admin 登入與
# KB 解鎖（解鎖後該密碼即可通過 admin Basic Auth）。
