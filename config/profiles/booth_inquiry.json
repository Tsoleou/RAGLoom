      "params": {
        "mode": "rule",
        "model": "gemma3:4b",
        "aliases": "{\n  \"starforge\": [\n    \"星鋒\",\n    \"星峰\"\n  ],\n  \"visionbook\": [\n    \"維森書\",\n    \"視覺書\"\n  ],\n  \"novapad\": [\n    \"諾瓦\",\n    \"諾瓦帕\"\n  ],\n  \"titanbook\": [\n    \"泰坦書\",\n    \"鈦書\"\n  ],\n  \"luminos\": [\n    \"璐米諾\",\n    \"流明\"\n  ]\n}"
